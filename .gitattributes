# Automatically normalize text files
* text=auto

# Documentation and source files should use LF line endings
*.md text eol=lf
*.txt text eol=lf

# PHP / Laravel
*.php text eol=lf
*.blade.php text eol=lf
*.env.example text eol=lf

# JavaScript / TypeScript / Vue
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.vue text eol=lf

# Frontend assets and config
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf

# Shell scripts usually run better with LF
*.sh text eol=lf

# Windows scripts should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.7z binary
